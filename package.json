{
  "name": "crs-sst-cdk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "cdk": "pnpm --filter @crs/infra cdk",
    "cdk:synth": "pnpm --filter @crs/infra cdk synth",
    "cdk:deploy": "pnpm --filter @crs/infra cdk deploy --all --outputs-file ../../cdk-outputs.json && scripts/sync-env.sh",
    "cdk:diff": "pnpm --filter @crs/infra cdk diff",
    "cdk:destroy": "scripts/cdk-destroy.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "debug": "lld",
    "dev": "pnpm --filter web dev",
    "dev:debug": "pnpm run dev & pnpm run debug",
    "env:sync": "scripts/sync-env.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "aws-cdk": "2.1116.0",
    "lambda-live-debugger": "^1.12.0",
    "typescript": "~5.9.3"
  }
}
