{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CDK: Deploy all stacks",
      "type": "shell",
      "command": "pnpm cdk:deploy"
    },
    {
      "label": "CDK: Watch for infra changes (hotswap)",
      "type": "shell",
      "command": "pnpm cdk watch --all --hotswap-fallback",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Detected change",
          "endsPattern": "deployment time"
        }
      }
    },
    {
      "label": "Lambda: Start Live Debugger (LLD)",
      "type": "shell",
      "command": "npx lld",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting the debugger",
          "endsPattern": "Debugger started!"
        }
      }
    },
    {
      "label": "Setup: Deploy → Watch → LLD",
      "dependsOn": [
        "CDK: Deploy all stacks",
        "CDK: Watch for infra changes (hotswap)",
        "Lambda: Start Live Debugger (LLD)"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "Env: Sync .env from CDK outputs",
      "type": "shell",
      "command": "scripts/sync-env.sh"
    },
    {
      "label": "Setup: Sync env → LLD",
      "dependsOn": [
        "Env: Sync .env from CDK outputs",
        "Lambda: Start Live Debugger (LLD)"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "Cleanup: Stop LLD + CDK Watch",
      "type": "shell",
      "command": "pkill -f lldebugger || true; pkill -f 'cdk watch' || true",
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
