{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CDK Watch",
      "type": "shell",
      "command": "pnpm cdk watch --all --hotswap",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Detected change",
          "endsPattern": "deployment time"
        }
      }
    },
    {
      "label": "Lambda Live Debugger",
      "type": "shell",
      "command": "npx lld",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting the debugger",
          "endsPattern": "Debugger started!"
        }
      }
    },
    {
      "label": "CDK Hotswap + LLD",
      "dependsOn": ["CDK Watch", "Lambda Live Debugger"],
      "dependsOrder": "sequence"
    },
    {
      "label": "Stop Lambda Live Debugger",
      "type": "shell",
      "command": "pkill -f lldebugger || true; pkill -f 'cdk watch' || true",
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
