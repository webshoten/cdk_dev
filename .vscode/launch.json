{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Lambda: Live Debugger (LLD only)",
      "runtimeExecutable": "npx",
      "args": ["lld"],
      "console": "integratedTerminal",
      "restart": true,
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Next.js: Dev Server only",
      "runtimeExecutable": "pnpm",
      "args": ["dev"],
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/packages/web/.env.local",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      },
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Dev: Lambda + Next.js + Chrome (no deploy)",
      "runtimeExecutable": "pnpm",
      "args": ["dev"],
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/packages/web/.env.local",
      "preLaunchTask": "Setup: Sync env → LLD",
      "postDebugTask": "Cleanup: Stop LLD + CDK Watch",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      },
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Full: Deploy + Watch + Lambda + Next.js + Chrome",
      "runtimeExecutable": "pnpm",
      "args": ["dev"],
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/packages/web/.env.local",
      "preLaunchTask": "Setup: Deploy → Watch → LLD",
      "postDebugTask": "Cleanup: Stop LLD + CDK Watch",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      },
      "cwd": "${workspaceFolder}"
    }
  ]
}
