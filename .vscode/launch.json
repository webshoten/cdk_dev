{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Lambda: Live Debugger (LLD)",
      "runtimeExecutable": "npx",
      "args": [
        "lld"
      ],
      "env": {
        "SKIP_NEXT_BUILD": "1"
      },
      "console": "integratedTerminal",
      "restart": true,
      "postDebugTask": "Cleanup: Remove LLD Layer",
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Next.js: Dev Server",
      "runtimeExecutable": "pnpm",
      "args": [
        "dev:web"
      ],
      "console": "integratedTerminal",
      "preLaunchTask": "Env: Sync config.json from CDK outputs",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      },
      "cwd": "${workspaceFolder}"
    }
  ]
}
