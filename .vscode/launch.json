{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Lambda Live Debugger",
      "runtimeExecutable": "npx",
      "args": ["lld"],
      "console": "integratedTerminal",
      "restart": true,
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Next.js Dev",
      "runtimeExecutable": "pnpm",
      "args": ["dev"],
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/packages/web/.env.local",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      },
      "cwd": "${workspaceFolder}/packages/web"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Full Debug (Lambda + Next.js)",
      "runtimeExecutable": "pnpm",
      "args": ["dev"],
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/packages/web/.env.local",
      "preLaunchTask": "Lambda Live Debugger",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      },
      "cwd": "${workspaceFolder}/packages/web"
    }
  ]
}
